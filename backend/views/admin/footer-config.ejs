<%- include('partials/head', { title: 'Footer Management' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'app-config' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="subnav">
        <a href="/admin/app-config">Banners</a>
        <a href="/admin/app-config/footer" class="active">Footer Management</a>
      </div>

      <div class="admin-page-header">
        <h1>Footer Management</h1>
      </div>
      <% if (ok) { %><p class="ok">Saved successfully.</p><% } %>
      <% if (deleted) { %><p class="ok">Footer config deleted.</p><% } %>
      <% if (error) { %><p class="error" style="color:var(--admin-danger);margin-bottom:1rem;"><%= error %></p><% } %>

      <div class="admin-form-card wide">
        <%
          const defaultSupportLinksText = [
            'Help Center',
            'Shipping & Delivery',
            'Terms & Privacy',
            'Returns Policy'
          ].join('\n');

          const supportLinksText = footerConfig && footerConfig.supportLinks && footerConfig.supportLinks.length
            ? footerConfig.supportLinks.join('\n')
            : defaultSupportLinksText;
        %>
        <form method="post" action="/admin/app-config/footer">
          <div class="grid2">
            <div>
              <label>Brand Name</label>
              <input type="text" name="brandName" value="<%= footerConfig ? (footerConfig.brandName || '') : '' %>" />
            </div>
            <div>
              <label>Support Email</label>
              <input type="email" name="supportEmail" value="<%= footerConfig ? (footerConfig.supportEmail || '') : '' %>" />
            </div>
          </div>

          <label>Brand Description</label>
          <textarea name="brandDescription"><%= footerConfig ? (footerConfig.brandDescription || '') : '' %></textarea>

          <div class="grid2">
            <div>
              <label>Support Phone</label>
              <input type="text" name="supportPhone" value="<%= footerConfig ? (footerConfig.supportPhone || '') : '' %>" />
            </div>
            <div>
              <label>Support Hours</label>
              <input type="text" name="supportHours" value="<%= footerConfig ? (footerConfig.supportHours || '') : '' %>" />
            </div>
          </div>

          <h3 style="margin-top:1.25rem;color:#fff;font-size:1rem;">Support Links</h3>
          <p class="muted" style="margin-top:0.25rem;">One per line.</p>
          <textarea name="supportLinks"><%= supportLinksText %></textarea>

          <h3 style="margin-top:1.25rem;color:#fff;font-size:1rem;">Social Links</h3>
          <div class="grid2">
            <div>
              <label>Facebook URL</label>
              <input type="text" name="facebookUrl" value="<%= footerConfig && footerConfig.social ? (footerConfig.social.facebookUrl || '') : '' %>" />
            </div>
            <div>
              <label>Instagram URL</label>
              <input type="text" name="instagramUrl" value="<%= footerConfig && footerConfig.social ? (footerConfig.social.instagramUrl || '') : '' %>" />
            </div>
            <div>
              <label>Twitter URL</label>
              <input type="text" name="twitterUrl" value="<%= footerConfig && footerConfig.social ? (footerConfig.social.twitterUrl || '') : '' %>" />
            </div>
            <div>
              <label>YouTube URL</label>
              <input type="text" name="youtubeUrl" value="<%= footerConfig && footerConfig.social ? (footerConfig.social.youtubeUrl || '') : '' %>" />
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Footer</button>
            <button type="button" class="btn btn-ghost" onclick="document.getElementById('deleteFooterForm').submit()">Delete</button>
          </div>
        </form>

        <form id="deleteFooterForm" method="post" action="/admin/app-config/footer/delete" style="display:none;">
          <input type="hidden" name="confirm" value="1" />
        </form>
      </div>
    </main>
    </div>
  </div>
</body>
</html>
