<%- include('partials/head', { title: 'Team Management' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'team' }) %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1>Team Management</h1>
        <p class="muted">Manage team cards shown on the public Team page.</p>
      </div>

      <div class="top-actions">
        <a href="/admin/team/new" class="btn btn-primary">Add Member</a>
      </div>

      <form class="table-toolbar" method="get" action="/admin/team">
        <label>Search
          <input type="search" name="q" value="<%= filters.q %>" placeholder="Name, role, description…" autocomplete="off" />
        </label>
        <label>Visibility
          <select name="active">
            <option value="">All</option>
            <option value="true" <%= filters.active === 'true' ? 'selected' : '' %>>Active</option>
            <option value="false" <%= filters.active === 'false' ? 'selected' : '' %>>Inactive</option>
          </select>
        </label>
        <label>Per page
          <select name="limit">
            <% [10, 20, 50].forEach(function(n) { %>
              <option value="<%= n %>" <%= pagination && pagination.limit === n ? 'selected' : '' %>><%= n %></option>
            <% }); %>
          </select>
        </label>
        <div class="toolbar-actions">
          <button type="submit" class="btn btn-primary">Apply</button>
          <a href="/admin/team" class="btn btn-ghost">Reset</a>
        </div>
      </form>

      <% if (!members || members.length === 0) { %>
        <div class="table-card">
          <div class="empty-state">
            <% if (filters.q || filters.active) { %>
              No members match your filters. <a href="/admin/team">Clear filters</a> or <a href="/admin/team/new">add a member</a>.
            <% } else { %>
              No team members yet. <a href="/admin/team/new">Add one</a>.
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="table-card">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Image</th>
                  <th>Name</th>
                  <th>Role</th>
                  <th>Description</th>
                  <th>Order</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% members.forEach(function(m) { %>
                  <tr>
                    <td>
                      <% if (m.imageUrl) { %>
                        <img src="<%= m.imageUrl %>" alt="" class="thumb round" />
                      <% } else { %>
                        <span class="muted">—</span>
                      <% } %>
                    </td>
                    <td><strong><%= m.name %></strong></td>
                    <td><%= m.role %></td>
                    <td><span class="muted"><%= m.description || '—' %></span></td>
                    <td><%= m.order || 0 %></td>
                    <td>
                      <span class="badge <%= m.active ? 'badge-active' : 'badge-inactive' %>">
                        <%= m.active ? 'active' : 'inactive' %>
                      </span>
                    </td>
                    <td>
                      <a href="/admin/team/edit/<%= m._id %>" class="btn btn-primary btn-sm">Edit</a>
                      <form method="post" action="/admin/team/<%= m._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this member?');">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <%- include('partials/pagination') %>
        </div>
      <% } %>
    </main>
  </div>
</body>
</html>
