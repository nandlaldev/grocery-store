<% 
  var _au = typeof adminUser !== 'undefined' ? adminUser : null;
  var _initials = 'A';
  if (_au && _au.fullName) {
    var _p = String(_au.fullName).trim().split(/\s+/).filter(Boolean);
    if (_p.length >= 2) _initials = (_p[0][0] + _p[1][0]).toUpperCase();
    else if (_p.length === 1) _initials = _p[0].slice(0, 2).toUpperCase();
  }
  var _profilePath = '/admin/profile';
  var _isProfile = typeof headerActive !== 'undefined' && headerActive === 'profile';
%>
<header class="admin-header">
  <% if (typeof headerTitle !== 'undefined' && headerTitle) { %>
  <div class="admin-header-title"><%= headerTitle %></div>
  <% } %>
  <button type="button" class="admin-theme-toggle" data-admin-theme-toggle aria-pressed="false" title="Theme">
    <span class="admin-theme-toggle__sun" aria-hidden="true">☀️</span>
    <span class="admin-theme-toggle__moon" aria-hidden="true">🌙</span>
    <span class="admin-theme-toggle__text">Theme</span>
  </button>
  <details class="admin-header-menu">
    <summary class="admin-header-trigger">
      <% if (_au && _au.avatarUrl) { %>
        <img src="<%= _au.avatarUrl %>" alt="" class="admin-header-avatar" width="40" height="40" />
      <% } else { %>
        <span class="admin-header-avatar admin-header-avatar-fallback" aria-hidden="true"><%= _initials %></span>
      <% } %>
      <span class="admin-header-name"><%= _au ? _au.fullName : 'Admin' %></span>
      <span class="admin-header-chevron" aria-hidden="true"></span>
    </summary>
    <div class="admin-header-dropdown" role="menu">
      <div class="admin-header-dropdown-meta">
        <strong><%= _au ? _au.fullName : 'Admin' %></strong>
        <span class="muted"><%= _au && _au.email ? _au.email : '' %></span>
      </div>
      <a href="<%= _profilePath %>" class="admin-header-dropdown-item <%= _isProfile ? 'is-active' : '' %>" role="menuitem">Edit profile</a>
      <a href="/admin/logout" class="admin-header-dropdown-item admin-header-dropdown-logout" role="menuitem">Logout</a>
    </div>
  </details>
</header>
