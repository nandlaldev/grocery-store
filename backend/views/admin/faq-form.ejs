<%- include('partials/head', { title: (faq ? 'Edit' : 'New') + ' FAQ' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'faqs' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1><%= faq ? 'Edit FAQ' : 'Add FAQ' %></h1>
      </div>
      <div class="admin-form-card">
        <% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %>
        <form method="post" action="<%= faq ? '/admin/faqs/' + faq._id : '/admin/faqs' %>">
          <label>Question *</label>
          <input type="text" name="question" value="<%= faq ? faq.question : '' %>" required />

          <label>Answer *</label>
          <textarea name="answer" required><%= faq ? faq.answer : '' %></textarea>

          <label>Order</label>
          <input type="number" name="order" min="0" value="<%= faq ? (faq.order ?? 0) : 0 %>" />

          <label style="margin-top:1rem;text-transform:none;">
            <input type="checkbox" name="active" <%= !faq || faq.active ? 'checked' : '' %> />
            Active (show on website)
          </label>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= faq ? 'Update' : 'Create' %> FAQ</button>
            <a href="/admin/faqs" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </main>
    </div>
  </div>
</body>
</html>
