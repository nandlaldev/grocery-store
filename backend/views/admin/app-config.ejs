<%- include('partials/head', { title: 'App Management' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'app-config' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="subnav">
        <a href="/admin/app-config" class="active">Banners</a>
        <a href="/admin/app-config/footer">Footer Management</a>
      </div>

      <div class="admin-page-header">
        <h1>App Management</h1>
        <p class="muted">Banners appear in the slider on the website home page. Order determines display order.</p>
      </div>

      <div class="top-actions">
        <a href="/admin/banners/new" class="btn btn-primary">Add Banner</a>
      </div>

      <form class="table-toolbar" method="get" action="/admin/app-config">
        <label>Search
          <input type="search" name="q" value="<%= filters.q %>" placeholder="Title or subtitle…" autocomplete="off" />
        </label>
        <label>Per page
          <select name="limit">
            <% [10, 20, 50].forEach(function(n) { %>
              <option value="<%= n %>" <%= pagination && pagination.limit === n ? 'selected' : '' %>><%= n %></option>
            <% }); %>
          </select>
        </label>
        <div class="toolbar-actions">
          <button type="submit" class="btn btn-primary">Apply</button>
          <a href="/admin/app-config" class="btn btn-ghost">Reset</a>
        </div>
      </form>

      <% if (!banners || banners.length === 0) { %>
        <div class="table-card">
          <div class="empty-state">
            <% if (filters.q) { %>
              No banners match your search. <a href="/admin/app-config">Clear</a> or <a href="/admin/banners/new">add a banner</a>.
            <% } else { %>
              No banners yet. <a href="/admin/banners/new">Add one</a>.
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="table-card">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Image</th>
                  <th>Title</th>
                  <th>Subtitle</th>
                  <th>Order</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% banners.forEach(function(b, i) { %>
                <tr>
                  <td><%= (pagination.page - 1) * pagination.limit + i + 1 %></td>
                  <td><img src="<%= b.imageUrl %>" alt="" class="banner-thumb" /></td>
                  <td><%= b.title || '—' %></td>
                  <td><%= b.subtitle || '—' %></td>
                  <td><%= b.order %></td>
                  <td>
                    <a href="/admin/banners/edit/<%= b._id %>" class="btn btn-primary btn-sm">Edit</a>
                    <form method="post" action="/admin/banners/<%= b._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this banner?');">
                      <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <%- include('partials/pagination') %>
        </div>
      <% } %>
    </main>
    </div>
  </div>
</body>
</html>
