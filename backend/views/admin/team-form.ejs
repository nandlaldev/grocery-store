<%- include('partials/head', { title: (member ? 'Edit' : 'New') + ' Team Member' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'team' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1><%= member ? 'Edit Team Member' : 'Add Team Member' %></h1>
      </div>
      <div class="admin-form-card">
        <% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %>
        <form method="post" action="<%= member ? '/admin/team/' + member._id : '/admin/team' %>" enctype="multipart/form-data">
          <label>Name *</label>
          <input type="text" name="name" value="<%= member ? member.name : '' %>" required />

          <label>Role *</label>
          <input type="text" name="role" value="<%= member ? member.role : '' %>" required />

          <label>Description</label>
          <textarea name="description"><%= member ? member.description : '' %></textarea>

          <label>Order</label>
          <input type="number" name="order" min="0" value="<%= member ? (member.order ?? 0) : 0 %>" />

          <label>Image</label>
          <input type="file" name="image" accept="image/*" />
          <% if (member && member.imageUrl) { %>
            <p style="margin-top:0.5rem;"><img class="thumb round" src="<%= member.imageUrl %>" alt="" /> Current image</p>
          <% } %>

          <label style="margin-top:1rem;text-transform:none;">
            <input type="checkbox" name="active" <%= !member || member.active ? 'checked' : '' %> />
            Active (show on website)
          </label>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= member ? 'Update' : 'Create' %> Member</button>
            <a href="/admin/team" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </main>
    </div>
  </div>
</body>
</html>
