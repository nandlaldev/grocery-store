<%- include('partials/head', { title: (banner ? 'Edit' : 'Add') + ' Banner' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'app-config' }) %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1><%= banner ? 'Edit Banner' : 'Add Banner' %></h1>
      </div>
      <div class="admin-form-card">
        <form method="post" action="<%= banner ? '/admin/banners/' + banner._id : '/admin/banners' %>" enctype="multipart/form-data">
          <label>Banner image <%= banner ? '(leave empty to keep current)' : '' %></label>
          <input type="file" name="banner" accept="image/*" <%= !banner ? 'required' : '' %> />
          <% if (banner && banner.imageUrl) { %>
            <p style="margin-top:0.5rem;">Current:</p>
            <img src="<%= banner.imageUrl %>" alt="" class="banner-preview" />
          <% } %>
          <label>Title (optional)</label>
          <input type="text" name="title" value="<%= banner ? banner.title : '' %>" placeholder="e.g. Fresh Groceries" />
          <label>Subtitle (optional)</label>
          <input type="text" name="subtitle" value="<%= banner ? banner.subtitle : '' %>" placeholder="e.g. Delivered to your door" />
          <label>Order (0 = first)</label>
          <input type="number" name="order" min="0" value="<%= banner ? banner.order : 0 %>" />
          <% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= banner ? 'Update' : 'Add' %> Banner</button>
            <a href="/admin/app-config" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </main>
  </div>
</body>
</html>
