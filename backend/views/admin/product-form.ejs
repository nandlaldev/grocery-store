<%- include('partials/head', { title: (product ? 'Edit' : 'Add') + ' Product' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'products' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1><%= product ? 'Edit Product' : 'Add Product' %></h1>
      </div>
      <div class="admin-form-card">
        <% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %>
        <form method="post" action="<%= product ? '/admin/products/' + product._id : '/admin/products' %>" enctype="multipart/form-data">
          <label>Name</label>
          <input type="text" name="name" value="<%= product ? product.name : '' %>" required />
          <label>Price (₹)</label>
          <input type="number" name="price" step="0.01" min="0" value="<%= product ? product.price : '' %>" required />
          <label>Stock Qty</label>
          <input type="number" name="qty" step="1" min="0" value="<%= product ? (product.qty ?? 0) : 0 %>" required />
          <label>Description</label>
          <textarea name="description"><%= product ? product.description : '' %></textarea>
          <label>Category</label>
          <input type="text" name="category" list="categories" value="<%= product ? product.category : '' %>" required />
          <datalist id="categories">
            <% (categories || []).forEach(function(c) { %><option value="<%= c %>"><% }); %>
          </datalist>
          <label>Image</label>
          <input type="file" name="image" accept="image/*" />
          <% if (product && product.imageUrl) { %><p><img class="thumb" src="<%= product.imageUrl %>" alt="" /> Current image</p><% } %>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= product ? 'Update' : 'Create' %> Product</button>
            <a href="/admin/products" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </main>
    </div>
  </div>
</body>
</html>
