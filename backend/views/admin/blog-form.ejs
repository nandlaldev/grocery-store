<%- include('partials/head', { title: 'Blog Management - ' + (post ? 'Edit Post' : 'New Post') }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'blogs' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1><%= post ? 'Edit Post' : 'New Post' %></h1>
      </div>
      <div class="admin-form-card wide">
        <% if (typeof error !== 'undefined' && error) { %><p class="error"><%= error %></p><% } %>
        <form method="post" action="<%= post ? '/admin/blogs/' + post._id : '/admin/blogs' %>" enctype="multipart/form-data" id="blogForm">
          <label>Title *</label>
          <input type="text" name="title" value="<%= post ? post.title : '' %>" required />
          <label>Excerpt (short summary)</label>
          <input type="text" name="excerpt" value="<%= post ? post.excerpt : '' %>" placeholder="Brief description for list view" />
          <label>Featured image (optional)</label>
          <input type="file" name="image" accept="image/*" />
          <% if (post && post.imageUrl) { %>
            <p style="margin-top:0.5rem;">Current: <img src="<%= post.imageUrl %>" alt="" style="max-height:60px;vertical-align:middle;border-radius:6px;" /></p>
          <% } %>
          <label>Content</label>
          <textarea name="content" id="content" class="raw"><%= post ? post.content : '' %></textarea>
          <label>Status</label>
          <select name="status">
            <option value="published" <%= post && post.status === 'published' ? 'selected' : '' %>>Published</option>
            <option value="draft" <%= post && post.status === 'draft' ? 'selected' : '' %>>Draft</option>
          </select>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= post ? 'Update' : 'Publish' %> Post</button>
            <a href="/admin/blogs" class="btn btn-ghost">Cancel</a>
          </div>
        </form>
      </div>
    </main>
    </div>
  </div>
  <script src="https://cdn.ckeditor.com/4.24.0-lts/full/ckeditor.js"></script>
  <script>
    function initCKEditor() {
      if (typeof CKEDITOR === 'undefined') {
        setTimeout(initCKEditor, 150);
        return;
      }
      var el = document.getElementById('content');
      if (el && el.value) {
        var div = document.createElement('div');
        div.innerHTML = el.value;
        el.value = div.innerHTML;
      }
      try {
        CKEDITOR.replace('content', {
          height: 320,
          removePlugins: 'elementspath',
          resize_enabled: true,
          toolbar: [
            { name: 'document', items: ['Source'] },
            { name: 'basicstyles', items: ['Bold', 'Italic', 'Underline', 'Strike'] },
            { name: 'paragraph', items: ['NumberedList', 'BulletedList', '-', 'Blockquote', '-', 'JustifyLeft', 'JustifyCenter', 'JustifyRight'] },
            { name: 'links', items: ['Link', 'Unlink'] },
            { name: 'styles', items: ['Format', 'Font', 'FontSize'] },
            { name: 'colors', items: ['TextColor', 'BGColor'] },
            { name: 'tools', items: ['Maximize'] }
          ]
        });
      } catch (e) {
        console.error('CKEditor init error:', e);
      }
      var form = document.getElementById('blogForm');
      if (form) {
        form.addEventListener('submit', function () {
          if (CKEDITOR.instances.content) CKEDITOR.instances.content.updateElement();
        });
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCKEditor);
    } else {
      initCKEditor();
    }
  </script>
</body>
</html>
