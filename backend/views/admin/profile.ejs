<%- include('partials/head', { title: 'My profile' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'profile' }) %>
    <div class="admin-content">
    <%- include('partials/header', { headerTitle: 'Profile', headerActive: 'profile' }) %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1>Edit profile</h1>
        <p class="muted">Left: save profile details. Right: change password (separate save).</p>
      </div>

      <% if (typeof ok !== 'undefined' && ok) { %>
        <p class="ok profile-flash profile-flash--ok">Profile details saved.</p>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <p class="error profile-flash profile-flash--err"><%= error %></p>
      <% } %>
      <% if (typeof pwdOk !== 'undefined' && pwdOk) { %>
        <p class="ok profile-flash profile-flash--ok">Password updated.</p>
      <% } %>
      <% if (typeof pwdError !== 'undefined' && pwdError) { %>
        <p class="error profile-flash profile-flash--err"><%= pwdError %></p>
      <% } %>

      <div class="profile-layout">
        <div class="admin-form-card">
          <form method="post" action="/admin/profile" enctype="multipart/form-data">
            <h2 class="profile-card-title">Profile details</h2>
            <label>Full name</label>
            <input type="text" name="fullName" value="<%= user.fullName %>" required />

            <label>Email</label>
            <input type="email" value="<%= user.email %>" disabled readonly />
            <p class="muted" style="margin-top:0.35rem;font-size:0.85rem;">Email cannot be changed here.</p>

            <label>Phone</label>
            <input type="text" name="phone" value="<%= user.phone || '' %>" placeholder="Optional" />

            <label>Profile photo</label>
            <input type="file" name="avatar" accept="image/*" />
            <% if (user.avatarUrl) { %>
              <p style="margin-top:0.5rem;"><img src="<%= user.avatarUrl %>" alt="" class="thumb" style="width:72px;height:72px;" /> Current photo</p>
            <% } %>

            <div class="form-actions profile-card-actions">
              <button type="submit" class="btn btn-primary">Save profile</button>
              <a href="/admin/profile" class="btn btn-ghost">Cancel</a>
              <a href="/admin" class="btn btn-ghost">Back to dashboard</a>
            </div>
          </form>
        </div>

        <div class="admin-form-card profile-password-card">
          <form method="post" action="/admin/profile/password" autocomplete="off">
            <h2 class="profile-card-title">Change password</h2>
            <p class="muted" style="margin-top:0;margin-bottom:1rem;font-size:0.85rem;">Use a strong password you don’t use elsewhere.</p>
            <label>Current password</label>
            <input type="password" name="currentPassword" autocomplete="current-password" required />
            <label>New password</label>
            <input type="password" name="newPassword" autocomplete="new-password" minlength="6" required />
            <label>Confirm new password</label>
            <input type="password" name="confirmPassword" autocomplete="new-password" minlength="6" required />

            <div class="form-actions profile-card-actions">
              <button type="submit" class="btn btn-primary">Save password</button>
              <a href="/admin/profile" class="btn btn-ghost">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </main>
    </div>
  </div>
</body>
</html>
