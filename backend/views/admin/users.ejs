<%- include('partials/head', { title: 'User Management' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'users' }) %>
    <div class="admin-content">
      <%- include('partials/header') %>
      <main class="admin-main">
        <div class="admin-page-header">
          <h1>User Management</h1>
          <p class="muted">Search by name, email, phone and view user profile details.</p>
        </div>

        <form class="table-toolbar" method="get" action="/admin/users">
          <label>Search
            <input type="search" name="q" value="<%= filters.q %>" placeholder="Name, email or phone..." autocomplete="off" />
          </label>
          <label>Role
            <select name="role">
              <option value="">All roles</option>
              <option value="customer" <%= filters.role === 'customer' ? 'selected' : '' %>>Customer</option>
              <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>
          </label>
          <label>Per page
            <select name="limit">
              <% [10, 20, 50].forEach(function(n) { %>
                <option value="<%= n %>" <%= pagination && pagination.limit === n ? 'selected' : '' %>><%= n %></option>
              <% }); %>
            </select>
          </label>
          <div class="toolbar-actions">
            <button type="submit" class="btn btn-primary">Apply</button>
            <a href="/admin/users" class="btn btn-ghost">Reset</a>
          </div>
        </form>

        <% if (!users || users.length === 0) { %>
          <div class="table-card">
            <div class="empty-state">
              <% if (filters.q || filters.role) { %>
                No users match your filters. <a href="/admin/users">Clear filters</a>.
              <% } else { %>
                No users yet.
              <% } %>
            </div>
          </div>
        <% } else { %>
          <div class="table-card">
            <div class="table-wrap">
              <table class="admin-table">
                <thead>
                  <tr>
                    <th>User Profile</th>
                    <th>Contact</th>
                    <th>Role</th>
                    <th>Joined</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach(function(u) { %>
                    <% const initials = (u.fullName || 'U').split(' ').filter(Boolean).slice(0, 2).map(function(n) { return n[0] ? n[0].toUpperCase() : ''; }).join('') || 'U'; %>
                    <tr>
                      <td>
                        <div style="display:flex;align-items:center;gap:0.75rem;">
                          <% if (u.avatarUrl) { %>
                            <img src="<%= u.avatarUrl %>" alt="<%= u.fullName %>" class="thumb round" />
                          <% } else { %>
                            <div class="thumb round" style="display:flex;align-items:center;justify-content:center;font-weight:700;color:#64748b;background:var(--admin-elevated);">
                              <%= initials %>
                            </div>
                          <% } %>
                          <div>
                            <div style="font-weight:600;"><%= u.fullName %></div>
                            <div class="muted" style="font-size:0.78rem;">ID: <%= u._id %></div>
                          </div>
                        </div>
                      </td>
                      <td>
                        <div><%= u.email %></div>
                        <div class="muted" style="font-size:0.82rem;"><%= u.phone || 'No phone' %></div>
                      </td>
                      <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
                      <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
            <%- include('partials/pagination') %>
          </div>
        <% } %>
      </main>
    </div>
  </div>
</body>
</html>