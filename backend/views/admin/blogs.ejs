<%- include('partials/head', { title: 'Blog' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'blogs' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1>Blog</h1>
        <p class="muted">Manage posts with search and status filters.</p>
      </div>

      <div class="top-actions">
        <a href="/admin/blogs/new" class="btn btn-primary">Add Post</a>
      </div>

      <form class="table-toolbar" method="get" action="/admin/blogs">
        <label>Search
          <input type="search" name="q" value="<%= filters.q %>" placeholder="Title or excerpt…" autocomplete="off" />
        </label>
        <label>Status
          <select name="status">
            <option value="">All</option>
            <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Published</option>
            <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
          </select>
        </label>
        <label>Per page
          <select name="limit">
            <% [10, 20, 50].forEach(function(n) { %>
              <option value="<%= n %>" <%= pagination && pagination.limit === n ? 'selected' : '' %>><%= n %></option>
            <% }); %>
          </select>
        </label>
        <div class="toolbar-actions">
          <button type="submit" class="btn btn-primary">Apply</button>
          <a href="/admin/blogs" class="btn btn-ghost">Reset</a>
        </div>
      </form>

      <% if (!posts || posts.length === 0) { %>
        <div class="table-card">
          <div class="empty-state">
            <% if (filters.q || filters.status) { %>
              No posts match your filters. <a href="/admin/blogs">Clear filters</a> or <a href="/admin/blogs/new">add a post</a>.
            <% } else { %>
              No posts yet. <a href="/admin/blogs/new">Add one</a>.
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="table-card">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% posts.forEach(function(p) { %>
                <tr>
                  <td><%= p.title %></td>
                  <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
                  <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
                  <td>
                    <a href="/admin/blogs/edit/<%= p._id %>" class="btn btn-primary btn-sm">Edit</a>
                    <form method="post" action="/admin/blogs/<%= p._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this post?');">
                      <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <%- include('partials/pagination') %>
        </div>
      <% } %>
    </main>
    </div>
  </div>
</body>
</html>
