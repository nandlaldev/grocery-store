<%- include('partials/head', { title: 'FAQ Management' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'faqs' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1>FAQ Management</h1>
        <p class="muted">Manage FAQ entries shown on the website FAQ page.</p>
      </div>

      <div class="top-actions">
        <a href="/admin/faqs/new" class="btn btn-primary">Add FAQ</a>
      </div>

      <form class="table-toolbar" method="get" action="/admin/faqs">
        <label>Search
          <input type="search" name="q" value="<%= filters.q %>" placeholder="Question or answer…" autocomplete="off" />
        </label>
        <label>Visibility
          <select name="active">
            <option value="">All</option>
            <option value="true" <%= filters.active === 'true' ? 'selected' : '' %>>Active</option>
            <option value="false" <%= filters.active === 'false' ? 'selected' : '' %>>Inactive</option>
          </select>
        </label>
        <label>Per page
          <select name="limit">
            <% [10, 20, 50].forEach(function(n) { %>
              <option value="<%= n %>" <%= pagination && pagination.limit === n ? 'selected' : '' %>><%= n %></option>
            <% }); %>
          </select>
        </label>
        <div class="toolbar-actions">
          <button type="submit" class="btn btn-primary">Apply</button>
          <a href="/admin/faqs" class="btn btn-ghost">Reset</a>
        </div>
      </form>

      <% if (!faqs || faqs.length === 0) { %>
        <div class="table-card">
          <div class="empty-state">
            <% if (filters.q || filters.active) { %>
              No FAQs match your filters. <a href="/admin/faqs">Clear filters</a> or <a href="/admin/faqs/new">add an FAQ</a>.
            <% } else { %>
              No FAQs yet. <a href="/admin/faqs/new">Add one</a>.
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="table-card">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Question</th>
                  <th>Answer</th>
                  <th>Order</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% faqs.forEach(function(f) { %>
                  <tr>
                    <td><strong><%= f.question %></strong></td>
                    <td><span class="muted"><%= f.answer %></span></td>
                    <td><%= f.order || 0 %></td>
                    <td>
                      <span class="badge <%= f.active ? 'badge-active' : 'badge-inactive' %>">
                        <%= f.active ? 'active' : 'inactive' %>
                      </span>
                    </td>
                    <td>
                      <a href="/admin/faqs/edit/<%= f._id %>" class="btn btn-primary btn-sm">Edit</a>
                      <form method="post" action="/admin/faqs/<%= f._id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this FAQ?');">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <%- include('partials/pagination') %>
        </div>
      <% } %>
    </main>
    </div>
  </div>
</body>
</html>
