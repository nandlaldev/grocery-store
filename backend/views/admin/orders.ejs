<%- include('partials/head', { title: 'Order Management' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'orders' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1>Order Management</h1>
        <p class="muted">Search customers or addresses, filter by status.</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert"><%= error %></div>
      <% } %>

      <form class="table-toolbar" method="get" action="/admin/orders">
        <label>Search
          <input type="search" name="q" value="<%= filters.q %>" placeholder="Name, phone, city…" autocomplete="off" />
        </label>
        <label>Status
          <select name="status">
            <option value="">All statuses</option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="confirmed" <%= filters.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
            <option value="delivered" <%= filters.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
          </select>
        </label>
        <label>Per page
          <select name="limit">
            <% [10, 20, 50].forEach(function(n) { %>
              <option value="<%= n %>" <%= pagination && pagination.limit === n ? 'selected' : '' %>><%= n %></option>
            <% }); %>
          </select>
        </label>
        <div class="toolbar-actions">
          <button type="submit" class="btn btn-primary">Apply</button>
          <a href="/admin/orders" class="btn btn-ghost">Reset</a>
        </div>
      </form>

      <% if (!orders || orders.length === 0) { %>
        <div class="table-card">
          <div class="empty-state">
            <% if (filters.q || filters.status) { %>
              No orders match your filters. <a href="/admin/orders">Clear filters</a>.
            <% } else { %>
              No orders yet.
            <% } %>
          </div>
        </div>
      <% } else { %>
        <div class="table-card">
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Customer</th>
                  <th>Address</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Update</th>
                </tr>
              </thead>
              <tbody>
                <% orders.forEach(function(o) { %>
                <tr>
                  <td><%= new Date(o.createdAt).toLocaleString() %></td>
                  <td><%= o.fullName %><br><small class="muted"><%= o.phone %></small></td>
                  <td><%= o.address %>, <%= o.city %> - <%= o.pincode %></td>
                  <td>₹<%= o.total %></td>
                  <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
                  <td>
                    <form method="post" action="/admin/orders/<%= o._id %>/status" style="display:inline;">
                      <select name="status" onchange="this.form.submit()">
                        <option value="pending" <%= o.status === 'pending' ? 'selected' : '' %>>Pending</option>
                        <option value="confirmed" <%= o.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                        <option value="delivered" <%= o.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                      </select>
                    </form>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <%- include('partials/pagination') %>
        </div>
      <% } %>
    </main>
    </div>
  </div>
</body>
</html>
