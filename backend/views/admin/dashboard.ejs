<%- include('partials/head', { title: 'Dashboard' }) %>
  <div class="admin-wrap">
    <%- include('partials/sidebar', { active: 'dashboard' }) %>
    <div class="admin-content">
    <%- include('partials/header') %>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1>Dashboard</h1>
        <p class="muted">Overview of store activity and quick access to product management.</p>
      </div>

      <section class="dashboard-grid" aria-label="Key metrics">
        <article class="dashboard-stat-card">
          <p class="dashboard-stat-label">Products</p>
          <p class="dashboard-stat-value"><%= stats.productsCount %></p>
          <a href="/admin/products" class="dashboard-stat-link">Open Product Management</a>
        </article>
        <article class="dashboard-stat-card">
          <p class="dashboard-stat-label">Customers</p>
          <p class="dashboard-stat-value"><%= stats.usersCount %></p>
          <a href="/admin/users" class="dashboard-stat-link">View Users</a>
        </article>
        <article class="dashboard-stat-card">
          <p class="dashboard-stat-label">Total Orders</p>
          <p class="dashboard-stat-value"><%= stats.totalOrders %></p>
          <a href="/admin/orders" class="dashboard-stat-link">Manage Orders</a>
        </article>
        <article class="dashboard-stat-card">
          <p class="dashboard-stat-label">Pending Orders</p>
          <p class="dashboard-stat-value"><%= stats.pendingOrders %></p>
          <a href="/admin/orders?status=pending" class="dashboard-stat-link">Open Pending</a>
        </article>
        <article class="dashboard-stat-card">
          <p class="dashboard-stat-label">Low Stock Products</p>
          <p class="dashboard-stat-value"><%= stats.lowStockProducts %></p>
          <a href="/admin/products?stock=low" class="dashboard-stat-link">Check Low Stock</a>
        </article>
        <article class="dashboard-stat-card">
          <p class="dashboard-stat-label">Confirmed Revenue</p>
          <p class="dashboard-stat-value">₹<%= Number(stats.revenue || 0).toLocaleString('en-IN') %></p>
          <a href="/admin/orders?status=confirmed" class="dashboard-stat-link">View Confirmed Orders</a>
        </article>
      </section>

      <section class="table-card" style="margin-top: 1.25rem;">
        <div class="table-card-head">
          <h2>Recent Orders</h2>
          <a href="/admin/orders" class="btn btn-ghost btn-sm">View all</a>
        </div>
        <% if (!recentOrders || recentOrders.length === 0) { %>
          <div class="empty-state">No recent orders yet.</div>
        <% } else { %>
          <div class="table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Customer</th>
                  <th>Total</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% recentOrders.forEach(function(o) { %>
                <tr>
                  <td><%= new Date(o.createdAt).toLocaleString() %></td>
                  <td><%= o.fullName %><br /><span class="muted"><%= o.phone %></span></td>
                  <td>₹<%= o.total %></td>
                  <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
    </div>
  </div>
</body>
</html>
